  "description": "Fan economy on Tether. Self-custodial wallet + tipping + group pools + match prediction, built with Tether WDK for the Tether Developers Cup",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "node src/server.js",
