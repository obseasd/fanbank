{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "public/**",
          "src/**",
          "node_modules/sodium-native/prebuilds/linux-x64/**",
          "node_modules/bare-*/prebuilds/linux-x64/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/api/index.js" }
  ]
}
