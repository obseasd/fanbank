    "@tetherto/wdk-wallet-evm-erc-4337": "^1.0.0-beta.11",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "solc": "^0.8.35"
  }
