# WDK seed for the fan wallet (BIP-39 mnemonic). Never commit real seeds.
WDK_SEED="test test test test test test test test test test test junk"

# EVM chain the fan wallet operates on.
# Default: Sepolia testnet (chainId 11155111) for the hackathon demo.
# Production would swap to a chain with cheap USDT: Polygon, BSC, Arbitrum.
CHAIN_ID=11155111
RPC_URL=https://rpc.sepolia.org

# USDT contract on the target chain. Sepolia mock deployed for the demo.
# The real Tether contract addresses live at https://tether.to/en/supported-protocols
USDT_ADDRESS=0x0000000000000000000000000000000000000000
USDT_DECIMALS=6

# Optional: Claude API key for the agent-wallet feature. If missing the
# agent falls back to a deterministic heuristic and the "AI: fallback"
# badge shows in the UI.
ANTHROPIC_API_KEY=

# Port for the local dashboard
PORT=3000
